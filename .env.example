# Convex self-hosted local development
# Copy this file to .env.local and fill secrets locally.

# Convex backend + CLI auth
CONVEX_SELF_HOSTED_URL=http://127.0.0.1:3210
CONVEX_SELF_HOSTED_ADMIN_KEY=replace-with-generated-admin-key

# Convex client URL used by frontend
NEXT_PUBLIC_CONVEX_URL=http://127.0.0.1:3210

# Optional: Convex HTTP actions/site proxy URL
NEXT_PUBLIC_CONVEX_SITE_URL=http://127.0.0.1:3211
